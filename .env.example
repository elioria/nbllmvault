# nbllmvault — environment

# Where notebook vaults + registry are stored (defaults to ./data)
# NBLLMVAULT_DATA=./data

# Backend port (frontend dev proxy targets this)
# PORT=8799

# ---- Optional LLM provider --------------------------------------------------
# With NO key set, nbllmvault runs fully offline using SwarmVault's built-in
# `heuristic` provider (extractive answers, no network). Set a key below to get
# richer NotebookLM-style synthesis. Applied to NEW notebooks at creation time.

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Override the model used for the configured provider.
# Anthropic default: claude-opus-4-8   |   OpenAI default: gpt-4o
# NBLLMVAULT_MODEL=claude-opus-4-8
